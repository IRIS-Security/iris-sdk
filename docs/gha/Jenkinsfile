// Jenkins declarative pipeline — IRIS governance with post { always } evidence

pipeline {
  agent any
  stages {
    stage('IRIS Governance') {
      steps {
        sh 'pip install iris-security-cli'
        sh 'iris compliance check --framework colorado-ai-act || true'
      }
    }
  }
  post {
    always {
      sh '''
        iris evidence record-cicd \
          --system jenkins \
          --run-id "${BUILD_ID}" \
          --pipeline-url "${BUILD_URL}" \
          --triggered-by "${BUILD_USER:-automated}" \
          --outcome "${currentBuild.currentResult}"
      '''
    }
  }
}
