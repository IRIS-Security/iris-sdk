// ============================================================
// IRIS Cedar Policy — demo-payment-agent
// Owner: platform-team@apexcapital.com (ai-platform)
// Data Classification: PII
// High-Risk AI: true (Colorado AI Act SB 24-205)
// Generated by: IRIS Policy Compiler v0.1.0
// Compliance: colorado-ai-act
// ============================================================


// ------------------------------------------------------------
// RULE 1: Read applicant credit data from credit bureau API
// Satisfies: CO-003 (transparency), CO-004 (data access controls)
// ------------------------------------------------------------
permit (
  principal == iris::AgentPassport::"demo-payment-agent",
  action    == iris::Action::"read",
  resource  == iris::API::"credit-bureau-api"
)
when {
  context.environment in ["dev", "staging", "production"] &&
  context.data_region in ["us-east-1", "us-west-2"] &&
  context.data_classification == "pii"
};


// ------------------------------------------------------------
// RULE 2: Call OpenAI for loan application analysis
// Satisfies: CO-004 (consent gate for consequential action)
// ------------------------------------------------------------
permit (
  principal == iris::AgentPassport::"demo-payment-agent",
  action    == iris::Action::"call",
  resource  == iris::API::"openai-api"
)
when {
  context.environment in ["dev", "staging", "production"] &&
  context.data_region in ["us-east-1", "us-west-2"] &&
  context.data_classification == "pii" &&
  context.user_consent_logged == true
};


// ------------------------------------------------------------
// RULE 3: Write transaction records to the internal ledger
// Satisfies: CO-004 (consent required before financial write)
// ------------------------------------------------------------
permit (
  principal == iris::AgentPassport::"demo-payment-agent",
  action    == iris::Action::"write",
  resource  == iris::Storage::"internal-ledger"
)
when {
  context.environment in ["staging", "production"] &&
  context.data_region in ["us-east-1", "us-west-2"] &&
  context.user_consent_logged == true
};


// ------------------------------------------------------------
// RULE 4 (HARD FORBID): Block access to PII outside US regions
// Satisfies: CO-004, data residency requirement
// ------------------------------------------------------------
forbid (
  principal == iris::AgentPassport::"demo-payment-agent",
  action    in [iris::Action::"read", iris::Action::"write",
                iris::Action::"call", iris::Action::"execute"],
  resource  == iris::DataClass::"pii"
)
unless {
  context.data_region in ["us-east-1", "us-west-2"]
};


// ------------------------------------------------------------
// RULE 5 (HARD FORBID): Block consequential loan decisions
//         without user consent — production guard
// Satisfies: CO-004 (CRITICAL — consequential decision gate)
// ------------------------------------------------------------
forbid (
  principal == iris::AgentPassport::"demo-payment-agent",
  action    in [iris::Action::"write", iris::Action::"call",
                iris::Action::"execute"],
  resource  in [iris::API::"openai-api", iris::Storage::"internal-ledger"]
)
when {
  context.environment == "production" &&
  context.user_consent_logged == false
};
